# =============================================================================
# AI Empire — Production Environment Template
# Copy to your hosting provider's env config (or `.env.production` locally).
# Do NOT commit real secrets. Replace every placeholder before deploy.
# =============================================================================

# Database — PostgreSQL required in production (Railway plugin auto-injects DATABASE_URL).
DATABASE_URL=postgresql://user:password@host:5432/ai_empire

# Anthropic Claude API — required for agent workflows and opportunity generation.
ANTHROPIC_API_KEY=

# Mutation API auth — REQUIRED when NODE_ENV=production (app fails fast without it).
# Generate a new secret; do not reuse this example value:
#   npx tsx -e "import { randomBytes } from 'node:crypto'; console.log(randomBytes(32).toString('hex'))"
EMPIRE_API_KEY=3091543342390b3b11f92bff82726f056965014cc5ea10449763485f6211164c

# Public HTTPS URL of your deployment (Checkout redirects, internal links).
APP_URL=

# Stripe live mode — replace sk_test_ / whsec_ test values before accepting payments.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
