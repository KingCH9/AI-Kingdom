# =============================================================================
# AI Empire — Environment Variables
# Copy this file to `.env` and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (SQLite — local development)
# Path is relative to the prisma/ directory.
# -----------------------------------------------------------------------------
DATABASE_URL="file:./dev.db"

# -----------------------------------------------------------------------------
# Anthropic Claude API
# Required for opportunity generation and agent workflows.
# Get a key at: https://console.anthropic.com/
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# -----------------------------------------------------------------------------
# Application URL
# Used by server-side code when an absolute URL is required.
# - Local dev:  http://localhost:3000
# - Production: set explicitly, e.g. https://your-domain.com
# - Vercel:     auto-detected via VERCEL_URL if APP_URL is unset
# -----------------------------------------------------------------------------
APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# API security (Lean 8A)
# When set, all mutation API routes require this key via:
#   - Header: x-api-key: <value>
#   - Header: Authorization: Bearer <value>
#
# When unset, mutation APIs are open (local development only).
#
# The dashboard UI uses Server Actions and does NOT need this key in the browser.
# Set this in production to protect external/cron API access.
# -----------------------------------------------------------------------------
# EMPIRE_API_KEY="generate-a-long-random-secret"  # REQUIRED when NODE_ENV=production

# Optional dashboard password for Server Action sessions (alternative to pasting API key).
# EMPIRE_ADMIN_PASSWORD="choose-a-strong-password"

# -----------------------------------------------------------------------------
# Stripe (Lean 8B webhook + Lean 8C checkout)
# Secret key: Dashboard → Developers → API keys (sk_test_... or sk_live_...).
# Required for POST /api/stores/[id]/checkout and store UI "Pay with Stripe".
# Webhook secret: Dashboard → Developers → Webhooks → signing secret.
# Required for POST /api/webhooks/stripe (checkout.session.completed).
# Checkout Session must include metadata.storeId or client_reference_id = store id.
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# -----------------------------------------------------------------------------
# Background task worker (Phase 4b / 7)
# Polls pending tasks through the domain execution engine.
# npm run task-worker
# ENABLE_TASK_WORKER="false"
# TASK_WORKER_INTERVAL_MS="30000"
# TASK_WORKER_BATCH_SIZE="10"
# TASK_WORKER_CRON_SECRET=""  # secures POST /api/tasks/worker/tick (or use EMPIRE_API_KEY)
# ENABLE_VALIDATOR_AUTOMATION="false"  # Atlas auto-validation in task-worker
# VALIDATOR_BATCH_SIZE="10"
# VALIDATOR_CRON_SECRET=""  # secures POST /api/validator/run-cycle (or use EMPIRE_API_KEY)

# -----------------------------------------------------------------------------
# Legacy worker (worker.ts) — DEPRECATED
# Use task-worker instead.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Node environment
# -----------------------------------------------------------------------------
NODE_ENV="development"
