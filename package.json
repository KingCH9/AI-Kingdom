{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "start:production": "node scripts/railway-start.mjs",
    "lint": "eslint .",
    "db:migrate:deploy": "node scripts/migrate-deploy.mjs",
    "db:railway:recover": "node scripts/railway-migrate-recover.mjs",
    "db:pipeline:status": "node scripts/pipeline-status.mjs",
    "db:diversity:batch": "tsx --env-file=.env scripts/diversity-batch-generate.ts",
    "db:railway:inspect": "node scripts/railway-migrate-recover.mjs --inspect",
    "db:verify-postgres": "tsx scripts/verify-postgres-migrations.ts",
    "worker": "tsx --env-file=.env worker.ts",
    "task-worker": "tsx --env-file=.env task-worker.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@prisma/client": "6.19.3",
    "@swc/helpers": "^0.5.23",
    "next": "16.2.7",
    "prisma": "6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.2.0",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
