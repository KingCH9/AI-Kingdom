# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# =============================================================================
# Secrets & environment (never commit)
# =============================================================================
.env
.env.local
.env.production
.env.development.local
.env.test.local
.env.production.local

# Railway PostgreSQL URL for local migration commands (never commit)
.env.railway

# Allow committed templates only
!.env.example
!.env.production.example

# =============================================================================
# Dependencies
# =============================================================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =============================================================================
# Next.js
# =============================================================================
/.next/
/out/
/build

# =============================================================================
# Local databases (may contain orders, customers, revenue)
# =============================================================================
*.db
*.db-journal
*.sqlite
*.sqlite3

# =============================================================================
# Logs
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =============================================================================
# Testing & coverage
# =============================================================================
/coverage

# =============================================================================
# Misc
# =============================================================================
.DS_Store
*.pem
.vercel
.cursor/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Generated / local runtime data
/data/intelligence-snapshot.json
/app/generated/prisma
