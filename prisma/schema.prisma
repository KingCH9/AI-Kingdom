generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Agent {
  id           Int      @id @default(autoincrement())
  name         String
  role         String
  level        Int      @default(1)
  xp           Int      @default(0)
  status       String   @default("active")
  departmentId Int?
  hqPersona    String?
  agentKind    String?
  subRoleKey   String?
  avatarKey    String?
  createdAt    DateTime @default(now())

  department   Department?  @relation(fields: [departmentId], references: [id])
  missionTasks MissionTask[]

  @@index([role])
  @@index([departmentId])
  @@index([hqPersona])
}

model Department {
  id               Int      @id @default(autoincrement())
  key              String   @unique
  name             String
  description      String   @default("")
  monthlyBudgetGbp Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  agents   Agent[]
  missions Mission[]
  budgets  Budget[]
}

model Mission {
  id               Int       @id @default(autoincrement())
  title            String
  description      String?
  status           String    @default("researching")
  ownerPersona     String
  departmentId     Int
  opportunityId    Int?      @unique
  storeId          Int?
  revenueStream    String    @default("shopify")
  revenueTier      Int       @default(1)
  targetRoi        Float?
  estimatedCostGbp Float     @default(0)
  actualCostGbp    Float     @default(0)
  approvedAt       DateTime?
  approvedBy       String?
  humanOverride    Boolean   @default(false)
  overrideReason   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  department  Department    @relation(fields: [departmentId], references: [id])
  opportunity Opportunity?  @relation(fields: [opportunityId], references: [id])
  store       Store?        @relation(fields: [storeId], references: [id])
  missionTasks MissionTask[]
  events      MissionEvent[]

  @@index([status])
  @@index([departmentId])
  @@index([ownerPersona])
  @@index([storeId])
}

model MissionTask {
  id               Int       @id @default(autoincrement())
  missionId        Int
  phase            String
  title            String
  status           String    @default("pending")
  ownerPersona     String
  assignedAgentId  Int?
  legacyTaskId     Int?
  sortOrder        Int       @default(0)
  estimatedCostGbp Float     @default(0)
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  mission       Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  assignedAgent Agent?  @relation(fields: [assignedAgentId], references: [id])
  legacyTask    Task?   @relation(fields: [legacyTaskId], references: [id])

  @@index([missionId])
  @@index([status])
  @@index([legacyTaskId])
}

model MissionEvent {
  id               Int      @id @default(autoincrement())
  missionId        Int
  agentPersona     String?
  action           String
  detail           String?
  estimatedCostGbp Float    @default(0)
  createdAt        DateTime @default(now())

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
}

model Budget {
  id            Int      @id @default(autoincrement())
  departmentId  Int
  periodMonth   String
  allocatedGbp  Float
  spentGbp      Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id])

  @@unique([departmentId, periodMonth])
}

model ConstitutionRule {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  title       String
  description String
  priority    Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Store {
  id            Int      @id @default(autoincrement())
  name          String
  slug          String?  @unique
  niche         String
  revenue       Float    @default(0)
  status        String
  opportunityId Int?
  createdAt     DateTime @default(now())

  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])
  products    Product[]
  productPage ProductPage?
  marketingLaunchPackage MarketingLaunchPackage?
  marketingAssets MarketingAsset[]
  shopAnalytics ShopAnalyticsEvent[]
  revenues    Revenue[]
  agentLogs   AgentLog[]
  customers   Customer[]
  orders      Order[]
  missions    Mission[]

  @@index([opportunityId])
}

model Customer {
  id         Int      @id @default(autoincrement())
  storeId    Int
  email      String
  name       String?
  orderCount Int      @default(0)
  totalSpent Float    @default(0)
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  store  Store   @relation(fields: [storeId], references: [id])
  orders Order[]

  @@unique([storeId, email])
  @@index([storeId])
}

model Order {
  id            Int      @id @default(autoincrement())
  storeId       Int
  customerId    Int
  productId     Int?
  opportunityId Int?
  externalId    String?
  source        String
  status        String   @default("paid")
  total         Float
  currency      String   @default("GBP")
  lineItemsJson String   @default("[]")
  placedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store       Store        @relation(fields: [storeId], references: [id])
  customer    Customer     @relation(fields: [customerId], references: [id])
  product     Product?     @relation(fields: [productId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])
  revenues    Revenue[]

  @@unique([source, externalId])
  @@index([storeId])
  @@index([customerId])
  @@index([productId])
  @@index([opportunityId])
  @@index([placedAt])
}

model ShopAnalyticsEvent {
  id        Int      @id @default(autoincrement())
  storeId   Int
  eventType String
  metadata  String   @default("{}")
  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([eventType])
  @@index([createdAt])
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  price     Float
  storeId   Int
  createdAt DateTime @default(now())

  store       Store        @relation(fields: [storeId], references: [id])
  productPage ProductPage?
  orders      Order[]
}

model ProductPage {
  id              Int      @id @default(autoincrement())
  storeId         Int      @unique
  productId       Int?     @unique
  heroHeadline    String
  subheadline     String
  salesCopy       String
  benefits        String   @default("[]")
  features        String   @default("[]")
  faq             String   @default("[]")
  ctaText         String   @default("Buy Now")
  seoTitle        String
  seoDescription  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store   Store    @relation(fields: [storeId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@index([storeId])
}

model MarketingLaunchPackage {
  id                  Int      @id @default(autoincrement())
  storeId             Int      @unique
  launchStrategy      String
  budgetTiers         String   @default("[]")
  tiktokStrategy      String
  metaStrategy        String
  influencerStrategy  String
  emailStrategy       String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id])

  @@index([storeId])
}

model MarketingAsset {
  id        Int      @id @default(autoincrement())
  storeId   Int
  assetType String
  title     String
  content   String
  platform  String
  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, assetType, title])
  @@index([storeId])
  @@index([assetType])
  @@index([platform])
}

model Revenue {
  id        Int      @id @default(autoincrement())
  amount    Float
  source    String
  storeId   Int
  orderId   Int?
  createdAt DateTime @default(now())

  store Store  @relation(fields: [storeId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model Opportunity {
  id                   Int      @id @default(autoincrement())

  productName          String
  productDescription   String?
  whyTrending          String?
  targetCustomer       String?

  sellingPrice         String?
  estimatedCostPerUnit String?
  profitMargin         String?

  supplierSearch       String?
  supplier             String?

  marketingAngles      String?
  tiktokIdeas          String?
  facebookAdIdeas      String?
  alibabaKeywords      String?
  launchPlan           String?

  category             String?
  demandScore          Int?
  competition          Int?

  riskRating           Int?
  opportunityScore     Int?

  status               String   @default("researching")

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  stores               Store[]
  orders               Order[]
  tasks                Task[]
  agentLogs            AgentLog[]
  mission              Mission?

  @@index([status])
  @@index([opportunityScore])
}

model Task {
  id            Int       @id @default(autoincrement())
  title         String
  agent         String
  status        String    @default("pending")
  result        String?
  opportunityId Int?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  opportunity  Opportunity?  @relation(fields: [opportunityId], references: [id])
  agentLogs    AgentLog[]
  missionTasks MissionTask[]

  @@index([status, createdAt])
  @@index([agent])
  @@index([opportunityId])
}

model AgentLog {
  id            Int      @id @default(autoincrement())
  agentName     String
  action        String
  opportunityId Int?
  taskId        Int?
  storeId       Int?
  createdAt     DateTime @default(now())

  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  task        Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  store       Store?       @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([agentName, createdAt])
  @@index([opportunityId])
  @@index([taskId])
  @@index([storeId])
}
